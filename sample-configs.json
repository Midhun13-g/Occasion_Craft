{
  "birthday_template_config": {
    "fields": [
      {
        "id": "name",
        "type": "text",
        "label": "Birthday Person Name",
        "placeholder": "Enter name",
        "required": true,
        "validation": {
          "min": 2,
          "max": 50,
          "message": "Name must be between 2 and 50 characters"
        }
      },
      {
        "id": "age",
        "type": "text",
        "label": "Age",
        "placeholder": "Enter age",
        "required": true
      },
      {
        "id": "message",
        "type": "textarea",
        "label": "Birthday Message",
        "placeholder": "Write your birthday wishes...",
        "required": true,
        "aiSuggestion": true,
        "validation": {
          "min": 10,
          "max": 500,
          "message": "Message must be between 10 and 500 characters"
        }
      },
      {
        "id": "primaryColor",
        "type": "color",
        "label": "Primary Color",
        "required": true,
        "defaultValue": "#FF6B9D"
      },
      {
        "id": "secondaryColor",
        "type": "color",
        "label": "Secondary Color",
        "required": true,
        "defaultValue": "#FFC93C"
      },
      {
        "id": "imageUrl",
        "type": "image",
        "label": "Background Image URL",
        "placeholder": "https://example.com/image.jpg",
        "required": false
      }
    ]
  },
  "wedding_template_config": {
    "fields": [
      {
        "id": "bride",
        "type": "text",
        "label": "Bride Name",
        "placeholder": "Enter bride name",
        "required": true
      },
      {
        "id": "groom",
        "type": "text",
        "label": "Groom Name",
        "placeholder": "Enter groom name",
        "required": true
      },
      {
        "id": "date",
        "type": "date",
        "label": "Wedding Date",
        "required": true
      },
      {
        "id": "venue",
        "type": "text",
        "label": "Venue",
        "placeholder": "Enter venue name",
        "required": true
      },
      {
        "id": "message",
        "type": "textarea",
        "label": "Invitation Message",
        "placeholder": "Write your invitation message...",
        "required": true,
        "aiSuggestion": true
      },
      {
        "id": "imageUrl",
        "type": "image",
        "label": "Cover Image URL",
        "placeholder": "https://example.com/image.jpg",
        "required": false
      }
    ]
  },
  "event_template_config": {
    "fields": [
      {
        "id": "eventName",
        "type": "text",
        "label": "Event Name",
        "placeholder": "Enter event name",
        "required": true
      },
      {
        "id": "eventType",
        "type": "select",
        "label": "Event Type",
        "required": true,
        "options": [
          { "value": "conference", "label": "Conference" },
          { "value": "workshop", "label": "Workshop" },
          { "value": "seminar", "label": "Seminar" },
          { "value": "meetup", "label": "Meetup" },
          { "value": "party", "label": "Party" }
        ]
      },
      {
        "id": "date",
        "type": "date",
        "label": "Event Date",
        "required": true
      },
      {
        "id": "time",
        "type": "text",
        "label": "Event Time",
        "placeholder": "e.g., 6:00 PM",
        "required": true
      },
      {
        "id": "venue",
        "type": "text",
        "label": "Venue",
        "placeholder": "Enter venue name",
        "required": true
      },
      {
        "id": "description",
        "type": "textarea",
        "label": "Event Description",
        "placeholder": "Describe your event...",
        "required": true,
        "aiSuggestion": true
      },
      {
        "id": "organizerName",
        "type": "text",
        "label": "Organizer Name",
        "placeholder": "Your name",
        "required": true
      },
      {
        "id": "organizerEmail",
        "type": "email",
        "label": "Contact Email",
        "placeholder": "your@email.com",
        "required": true
      },
      {
        "id": "organizerPhone",
        "type": "tel",
        "label": "Contact Phone",
        "placeholder": "+91 1234567890",
        "required": false
      },
      {
        "id": "primaryColor",
        "type": "color",
        "label": "Theme Color",
        "required": true,
        "defaultValue": "#2563EB"
      },
      {
        "id": "imageUrl",
        "type": "image",
        "label": "Event Banner URL",
        "placeholder": "https://example.com/banner.jpg",
        "required": false
      }
    ]
  },
  "portfolio_template_config": {
    "fields": [
      {
        "id": "fullName",
        "type": "text",
        "label": "Full Name",
        "placeholder": "Enter your full name",
        "required": true
      },
      {
        "id": "title",
        "type": "text",
        "label": "Professional Title",
        "placeholder": "e.g., Full Stack Developer",
        "required": true
      },
      {
        "id": "bio",
        "type": "textarea",
        "label": "Bio",
        "placeholder": "Tell us about yourself...",
        "required": true,
        "aiSuggestion": true
      },
      {
        "id": "email",
        "type": "email",
        "label": "Email",
        "placeholder": "your@email.com",
        "required": true
      },
      {
        "id": "phone",
        "type": "tel",
        "label": "Phone",
        "placeholder": "+91 1234567890",
        "required": false
      },
      {
        "id": "skills",
        "type": "textarea",
        "label": "Skills (comma-separated)",
        "placeholder": "React, Node.js, TypeScript",
        "required": true
      },
      {
        "id": "experience",
        "type": "textarea",
        "label": "Experience",
        "placeholder": "List your work experience...",
        "required": true
      },
      {
        "id": "education",
        "type": "textarea",
        "label": "Education",
        "placeholder": "Your educational background...",
        "required": true
      },
      {
        "id": "profileImage",
        "type": "image",
        "label": "Profile Image URL",
        "placeholder": "https://example.com/profile.jpg",
        "required": false
      },
      {
        "id": "accentColor",
        "type": "color",
        "label": "Accent Color",
        "required": true,
        "defaultValue": "#6366F1"
      }
    ]
  },
